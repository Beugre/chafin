rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Règles pour les documents utilisateur (justificatifs d'identité, etc.)
    match /users/{userId}/documents/{documentId} {
      // Un utilisateur peut uploader ses propres documents
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024 // Max 5MB
        && request.resource.contentType.matches('image/.*|application/pdf');
      
      // Un utilisateur peut lire ses propres documents, les admins peuvent lire tous les documents
      allow read: if request.auth != null && 
        (request.auth.uid == userId ||
         (exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
          get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superAdmin']));
    }
    
    // Règles pour les contrats et échéanciers générés
    match /loans/{loanId}/contracts/{contractId} {
      // Seuls les admins peuvent créer/modifier les contrats
      allow write: if request.auth != null && 
        exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superAdmin'];
      
      // L'utilisateur propriétaire du prêt et les admins peuvent lire
      allow read: if request.auth != null &&
        (exists(/databases/(default)/documents/loans/$(loanId)) &&
         (get(/databases/(default)/documents/loans/$(loanId)).data.userId == request.auth.uid ||
          (exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
           get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superAdmin'])));
    }
    
    // Règles pour les preuves de paiement
    match /loans/{loanId}/payments/{paymentId} {
      // Les admins peuvent uploader des preuves de paiement
      allow write: if request.auth != null && 
        exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superAdmin']
        && request.resource.size < 10 * 1024 * 1024; // Max 10MB
      
      // L'utilisateur propriétaire du prêt et les admins peuvent lire
      allow read: if request.auth != null &&
        (exists(/databases/(default)/documents/loans/$(loanId)) &&
         (get(/databases/(default)/documents/loans/$(loanId)).data.userId == request.auth.uid ||
          (exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
           get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superAdmin'])));
    }
    
    // Bloquer tout le reste
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
