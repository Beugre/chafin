rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // RÈGLES TEMPORAIRES POUR DÉVELOPPEMENT - À SÉCURISER EN PRODUCTION
    // Permettre toutes les opérations pour résoudre les problèmes d'accès
    match /{document=**} {
      allow read, write: if true;
    }

  }
}
